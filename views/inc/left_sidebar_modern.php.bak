<?php
/**
 * Modern Left Sidebar — Tailwind + Alpine.js
 * Replaces the legacy Bootstrap sidebar visually while keeping the same menu structure.
 * Uses tw- prefix to avoid CSS conflicts.
 */

// Greeting logic
date_default_timezone_set("" . $core->timezone . "");
$t = date("H");
if ($t < 12) {
    $mensaje = $lang['message1'];
} elseif ($t < 18) {
    $mensaje = $lang['message2'];
} else {
    $mensaje = $lang['message3'];
}

$avatar = ($userData->avatar) ? $userData->avatar : "uploads/blank.png";
$current_page = basename($_SERVER['PHP_SELF']);

// Helper: render a single sidebar link
function sb_link($href, $icon, $label, $current_page) {
    $active = (basename($href) === $current_page);
    $active_cls = $active 
        ? 'tw-bg-blue-600/10 tw-text-blue-400 tw-font-medium' 
        : 'tw-text-gray-400 hover:tw-text-gray-200 hover:tw-bg-white/5';
    $indicator = $active ? '<div class="tw-absolute tw-left-0 tw-top-1 tw-bottom-1 tw-w-0.5 tw-bg-blue-500 tw-rounded-r"></div>' : '';
    echo '<a href="' . htmlspecialchars($href) . '" class="tw-relative tw-flex tw-items-center tw-gap-2.5 tw-px-4 tw-py-2 tw-rounded-lg tw-text-sm tw-transition-colors ' . $active_cls . '">';
    echo $indicator;
    echo '<i data-lucide="' . htmlspecialchars($icon) . '" class="tw-w-4 tw-h-4 tw-shrink-0"></i>';
    echo '<span class="sidebar-label">' . $label . '</span>';
    echo '</a>';
}

// Helper: render a submenu group
function sb_group_start($icon, $label, $id) {
    echo '<div x-data="{ open: false }" class="tw-mb-0.5">';
    echo '<button @click="open = !open" class="tw-w-full tw-flex tw-items-center tw-gap-2.5 tw-px-4 tw-py-2 tw-rounded-lg tw-text-sm tw-text-gray-400 hover:tw-text-gray-200 hover:tw-bg-white/5 tw-transition-colors">';
    echo '<i data-lucide="' . htmlspecialchars($icon) . '" class="tw-w-4 tw-h-4 tw-shrink-0"></i>';
    echo '<span class="tw-flex-1 tw-text-left sidebar-label">' . $label . '</span>';
    echo '<i data-lucide="chevron-down" class="tw-w-3.5 tw-h-3.5 tw-transition-transform tw-duration-200" :class="open && \'tw-rotate-180\'"></i>';
    echo '</button>';
    echo '<div x-show="open" x-collapse x-cloak class="tw-pl-4 tw-mt-0.5 tw-space-y-0.5">';
}

function sb_group_end() {
    echo '</div></div>';
}

function sb_section_label($label) {
    echo '<div class="tw-px-4 tw-pt-4 tw-pb-1"><p class="tw-text-[10px] tw-font-semibold tw-text-gray-500 tw-uppercase tw-tracking-wider sidebar-label">' . htmlspecialchars($label) . '</p></div>';
}

// Helper: render a sub-submenu group (nested)
function sb_subgroup_start($icon, $label) {
    echo '<div x-data="{ subOpen: false }" class="tw-mb-0.5">';
    echo '<button @click="subOpen = !subOpen" class="tw-w-full tw-flex tw-items-center tw-gap-2.5 tw-px-3 tw-py-1.5 tw-rounded-lg tw-text-xs tw-text-gray-400 hover:tw-text-gray-200 hover:tw-bg-white/5 tw-transition-colors">';
    echo '<i data-lucide="' . htmlspecialchars($icon) . '" class="tw-w-3.5 tw-h-3.5 tw-shrink-0"></i>';
    echo '<span class="tw-flex-1 tw-text-left sidebar-label">' . $label . '</span>';
    echo '<i data-lucide="chevron-down" class="tw-w-3 tw-h-3 tw-transition-transform tw-duration-200" :class="subOpen && \'tw-rotate-180\'"></i>';
    echo '</button>';
    echo '<div x-show="subOpen" x-collapse x-cloak class="tw-pl-3 tw-mt-0.5 tw-space-y-0.5">';
}

function sb_subgroup_end() {
    echo '</div></div>';
}

function sb_sublink($href, $label, $current_page) {
    $active = (basename($href) === $current_page);
    $cls = $active ? 'tw-text-blue-400 tw-font-medium' : 'tw-text-gray-500 hover:tw-text-gray-300';
    echo '<a href="' . htmlspecialchars($href) . '" class="tw-flex tw-items-center tw-gap-2 tw-px-3 tw-py-1.5 tw-rounded-md tw-text-xs tw-transition-colors ' . $cls . '">';
    echo '<span class="tw-w-1 tw-h-1 tw-rounded-full ' . ($active ? 'tw-bg-blue-400' : 'tw-bg-gray-600') . '"></span>';
    echo '<span class="sidebar-label">' . $label . '</span>';
    echo '</a>';
}
